def is_probable_name(text):
    """
    Strictly filters out award titles, navigation, and UI elements.
    """
    if not text:
        return False

    text = text.strip()

    # 1. Length check (Names are usually 2-4 words, rarely over 50 chars)
    if len(text) < 3 or len(text) > 45:
        return False

    # 2. Digit check (Names don't have numbers like "2023" or "2024")
    if re.search(r"\d", text):
        return False

    # 3. NOISE FILTER: Specifically target "Keppel", "Award", and Page Headers
    # If any of these words are in the string, it's likely NOT a student name.
    noise_keywords = [
        "Award", "Scholarship", "Keppel", "Step-it-up", "Health", 
        "Service", "Leadership", "Excellence", "Prize", "Grant",
        "Year", "Sophomore", "Junior", "Senior", "Freshmore",
        "Pillar", "Contact", "Sitemap", "About", "Home", "Campus",
        "Admissions", "Research", "Student Life", "Back to", "Top",
        "Terms", "Privacy", "Feedback", "SUTD", "Honours List"
    ]
    
    if any(word.lower() in text.lower() for word in noise_keywords):
        return False

    # 4. Character check (Only letters and common name punctuation)
    return bool(re.match(r"^[A-Za-z ,.'-]+$", text))

def scrape_honours_page(url):
    """
    Targets only the list items within the main content body.
    """
    try:
        response = requests.get(url, timeout=15)
        response.raise_for_status()
        soup = BeautifulSoup(response.text, "html.parser")

        names = []
        
        # SUTD main content usually lives in 'col-md-9'
        main_content = soup.find("div", class_="col-md-9")
        if not main_content:
            main_content = soup.find("article") or soup

        # We look for <li> tags specifically to find name lists
        for li in main_content.find_all("li"):
            # Ensure we aren't pulling menu links from the sidebar/footer if they bled in
            if li.find('a', href=True) and len(li.get_text()) > 20:
                # If it's a long link, it's probably a navigation item, not a name
                continue
                
            text = li.get_text(strip=True)
            if is_probable_name(text):
                names.append(text)

        return names
    except Exception as e:
        print(f"Error scraping {url}: {e}")
        return []

